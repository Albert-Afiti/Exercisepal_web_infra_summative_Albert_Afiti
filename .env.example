# Copy this file to .env and fill in the values.
# Never commit .env — it is excluded by .gitignore.

# RapidAPI key for ExerciseDB
# Get a free key at: https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb
RAPIDAPI_KEY=your_rapidapi_key_here

# Port the Node.js server listens on (default: 3000)
PORT=3000

# CORS allowed origin — set to your load balancer URL in production
# Example: http://192.168.1.20
ALLOWED_ORIGIN=http://localhost:3000
